      "id": "t-worker-b",
      "type": "text",
      "x": 420,
      "y": 162,
      "width": 330,
      "height": 250,
      "fontSize": 13,
      "fontFamily": 3,
      "text": "\u2022 serves built SPA (ASSETS binding)\n\n\u2022 /api/data        \u2014 ESPN     (~10s cache)\n\u2022 /api/titleodds   \u2014 Polymarket (~300s)\n\u2022 /api/winprob     \u2014 Polymarket (~60s)\n\n\u2022 edge cache: one upstream fetch\n  fans out to all users",
      "originalText": "\u2022 serves built SPA (ASSETS binding)\n\n\u2022 /api/data        \u2014 ESPN     (~10s cache)\n\u2022 /api/titleodds   \u2014 Polymarket (~300s)\n\u2022 /api/winprob     \u2014 Polymarket (~60s)\n\n\u2022 edge cache: one upstream fetch\n  fans out to all users",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "lineHeight": 1.25,
      "baseline": 11
    },
